<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox prefHeight="600.0" prefWidth="900.0"
      stylesheets="@/peluqueria/Css/clientes.css"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="peluqueria.Controllers.EstilistasController">

    <!-- SIDEBAR -->
    <VBox prefWidth="200" styleClass="sidebar" spacing="5">
        <padding>
            <Insets top="20" bottom="20" left="10" right="10"/>
        </padding>
        <Label text="PELUQUERIA" styleClass="sidebar-title"/>
        <Label text="Sistema de Gestion" styleClass="sidebar-subtitle"/>
        <Region prefHeight="20"/>
        <Button text="Inicio" styleClass="sidebar-btn" onAction="#irDashboard" maxWidth="Infinity"/>
        <Button text="Citas" styleClass="sidebar-btn" onAction="#irCitas" maxWidth="Infinity"/>
        <Button text="Clientes" styleClass="sidebar-btn" onAction="#irClientes" maxWidth="Infinity"/>
        <Button text="Servicios" styleClass="sidebar-btn" onAction="#irServicios" maxWidth="Infinity"/>
        <Button text="Estilistas" styleClass="sidebar-btn-active" onAction="#irEstilistas" maxWidth="Infinity"/>
        <Button text="Usuarios" styleClass="sidebar-btn" onAction="#irUsuarios" maxWidth="Infinity"/>
        <Button text="Caja" styleClass="sidebar-btn" onAction="#irCaja" maxWidth="Infinity"/>
        <Button text="Pagos" styleClass="sidebar-btn" onAction="#irPagos" maxWidth="Infinity"/>
        <Button text="Facturacion" styleClass="sidebar-btn" onAction="#irFacturacion" maxWidth="Infinity"/>
        <Region VBox.vgrow="ALWAYS"/>
        <Button text="Cerrar Sesion" styleClass="sidebar-btn-logout" onAction="#cerrarSesion" maxWidth="Infinity"/>
    </VBox>

    <!-- CONTENIDO -->
    <VBox styleClass="contenido" spacing="15" HBox.hgrow="ALWAYS">
        <padding>
            <Insets top="25" right="25" bottom="25" left="25"/>
        </padding>

        <Label text="Gestion de Estilistas" styleClass="titulo"/>
        <Label text="Registre y administre los estilistas de la peluqueria" styleClass="fecha"/>

        <!-- FORMULARIO -->
        <VBox styleClass="card" spacing="15">
            <Label text="Datos del Estilista" styleClass="form-seccion"/>

            <GridPane hgap="15" vgap="12">
                <columnConstraints>
                    <ColumnConstraints percentWidth="33.33"/>
                    <ColumnConstraints percentWidth="33.33"/>
                    <ColumnConstraints percentWidth="33.33"/>
                </columnConstraints>

                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label text="Nombre *" styleClass="label-form"/>
                    <TextField fx:id="txtNombre" promptText="Ej: Maria Lopez" styleClass="campo-texto"/>
                </VBox>

                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label text="Teléfono *" styleClass="label-form"/>
                    <TextField fx:id="txtTelefono" promptText="Ej: 0999-123-456" styleClass="campo-texto"/>
                </VBox>

                <VBox spacing="5" GridPane.columnIndex="2" GridPane.rowIndex="0">
                    <Label text="Especialidad *" styleClass="label-form"/>
                    <TextField fx:id="txtEspecialidad" promptText="Ej: Colorimetria" styleClass="campo-texto"/>
                </VBox>

                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <Label text="Experiencia (anios)" styleClass="label-form"/>
                    <TextField fx:id="txtExperiencia" promptText="Ej: 5" styleClass="campo-texto"/>
                </VBox>

                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <Label text="Estado *" styleClass="label-form"/>
                    <ComboBox fx:id="cmbEstado" promptText="Seleccione estado" maxWidth="Infinity" styleClass="campo-texto"/>
                </VBox>

                <VBox spacing="5" GridPane.columnIndex="2" GridPane.rowIndex="1">
                    <Label text="Usuario Asociado *" styleClass="label-form"/>
                    <ComboBox fx:id="cmbUsuario" promptText="Seleccione usuario" maxWidth="Infinity" styleClass="campo-texto"/>
                </VBox>
            </GridPane>

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Label fx:id="lblMensaje" styleClass="mensaje"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Limpiar" styleClass="btn-secundario" onAction="#limpiarFormulario"/>
                <Button text="Editar" styleClass="btn-secundario" onAction="#editarEstilista"/>
                <Button text="Guardar Nuevo" styleClass="btn-accion" onAction="#guardarEstilista"/>
            </HBox>
        </VBox>

        <!-- TABLA -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Estilistas Registrados" styleClass="subtitulo"/>
            <Region HBox.hgrow="ALWAYS"/>
            <TextField fx:id="txtBuscar" promptText="Buscar estilista..." styleClass="campo-buscar"/>
        </HBox>

        <TableView fx:id="tablaEstilistas" styleClass="tabla-citas" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colNombre" text="Nombre" prefWidth="150"/>
                <TableColumn fx:id="colTelefono" text="Telefono" prefWidth="120"/>
                <TableColumn fx:id="colEspecialidad" text="Especialidad" prefWidth="150"/>
                <TableColumn fx:id="colExperiencia" text="Experiencia" prefWidth="100"/>
                <TableColumn fx:id="colEstado" text="Estado" prefWidth="100"/>
            </columns>
        </TableView>
    </VBox>
</HBox>
