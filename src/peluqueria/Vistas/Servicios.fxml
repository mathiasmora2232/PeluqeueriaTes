<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox prefHeight="600.0" prefWidth="900.0"
      stylesheets="@/peluqueria/Css/clientes.css"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="peluqueria.Controllers.ServiciosController">

    <!-- SIDEBAR -->
    <VBox prefWidth="200" styleClass="sidebar" spacing="5">
        <padding>
            <Insets top="20" bottom="20" left="10" right="10"/>
        </padding>
        <Label text="PELUQUERIA" styleClass="sidebar-title"/>
        <Label text="Sistema de Gestion" styleClass="sidebar-subtitle"/>
        <Region prefHeight="20"/>
        <Button text="Inicio" styleClass="sidebar-btn" onAction="#irDashboard" maxWidth="Infinity"/>
        <Button text="Citas" styleClass="sidebar-btn" onAction="#irCitas" maxWidth="Infinity"/>
        <Button text="Clientes" styleClass="sidebar-btn" onAction="#irClientes" maxWidth="Infinity"/>
        <Button text="Servicios" styleClass="sidebar-btn-active" onAction="#irServicios" maxWidth="Infinity"/>
        <Button text="Estilistas" styleClass="sidebar-btn" onAction="#irEstilistas" maxWidth="Infinity"/>
        <Button text="Usuarios" styleClass="sidebar-btn" onAction="#irUsuarios" maxWidth="Infinity"/>
        <Button text="Caja" styleClass="sidebar-btn" onAction="#irCaja" maxWidth="Infinity"/>
        <Button text="Pagos" styleClass="sidebar-btn" onAction="#irPagos" maxWidth="Infinity"/>
        <Button text="Facturacion" styleClass="sidebar-btn" onAction="#irFacturacion" maxWidth="Infinity"/>
        <Region VBox.vgrow="ALWAYS"/>
        <Button text="Cerrar Sesion" styleClass="sidebar-btn-logout" onAction="#cerrarSesion" maxWidth="Infinity"/>
    </VBox>

    <!-- CONTENIDO -->
    <VBox styleClass="contenido" spacing="15" HBox.hgrow="ALWAYS">
        <padding>
            <Insets top="25" right="25" bottom="25" left="25"/>
        </padding>

        <Label text="Gestion de Servicios" styleClass="titulo"/>
        <Label text="Registre y administre los servicios de la peluqueria" styleClass="fecha"/>

        <!-- FORMULARIO -->
        <VBox styleClass="card" spacing="15">
            <Label text="Datos del Servicio" styleClass="form-seccion"/>

            <GridPane hgap="15" vgap="12">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50"/>
                    <ColumnConstraints percentWidth="50"/>
                </columnConstraints>

                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label text="Nombre *" styleClass="label-form"/>
                    <TextField fx:id="txtNombre" promptText="Ej: Corte de Cabello" styleClass="campo-texto"/>
                </VBox>

                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label text="Precio *" styleClass="label-form"/>
                    <TextField fx:id="txtPrecio" promptText="Ej: 15.00" styleClass="campo-texto"/>
                </VBox>

                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <Label text="Duracion (minutos)" styleClass="label-form"/>
                    <TextField fx:id="txtDuracion" promptText="Ej: 30" styleClass="campo-texto"/>
                </VBox>

                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <Label text="Descripcion" styleClass="label-form"/>
                    <TextField fx:id="txtDescripcion" promptText="Ej: Corte clasico" styleClass="campo-texto"/>
                </VBox>
            </GridPane>

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Label fx:id="lblMensaje" styleClass="mensaje"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Limpiar" styleClass="btn-secundario" onAction="#limpiarFormulario"/>
                <Button text="Desactivar" styleClass="btn-secundario" onAction="#eliminarServicio"/>
                <Button text="Editar" styleClass="btn-secundario" onAction="#editarServicio"/>
                <Button text="Guardar Nuevo" styleClass="btn-accion" onAction="#guardarServicio"/>
            </HBox>
        </VBox>

        <!-- TABLA -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Servicios Registrados" styleClass="subtitulo"/>
            <Region HBox.hgrow="ALWAYS"/>
            <TextField fx:id="txtBuscar" promptText="Buscar servicio..." styleClass="campo-buscar"/>
        </HBox>

        <TableView fx:id="tablaServicios" styleClass="tabla-citas" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colNombre" text="Nombre" prefWidth="180"/>
                <TableColumn fx:id="colPrecio" text="Precio" prefWidth="100"/>
                <TableColumn fx:id="colDuracion" text="Duracion (min)" prefWidth="120"/>
                <TableColumn fx:id="colDescripcion" text="Descripcion" prefWidth="250"/>
            </columns>
        </TableView>
    </VBox>
</HBox>
