<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="700.0" prefWidth="1000.0" spacing="20.0" 
      stylesheets="@/peluqueria/Css/PublicScheduling.css"
      style="-fx-padding: 30; -fx-background-color: #f5f5f5;"
      xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="peluqueria.Controllers.Agendamiendo">

    <!-- Header con título y botón admin -->
    <HBox spacing="20.0" alignment="TOP_RIGHT">
        <VBox HBox.hgrow="ALWAYS" spacing="10.0">
            <Label text="✂ AGENDAR CITA" styleClass="header-title"/>
            <Label text="Bienvenido a nuestro sistema de citas. Complete el formulario para agendar su cita." 
                   styleClass="header-subtitle"/>
        </VBox>
        <Button fx:id="btnAdmin" text="👤 Admin" onAction="#abrirLogin" styleClass="btn-admin"/>
    </HBox>

    <!-- Formulario -->
    <VBox spacing="15.0" styleClass="form-card">
        
        <!-- Datos personales -->
        <Label text="DATOS PERSONALES" styleClass="section-title"/>
        
        <HBox spacing="20.0">
            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                <Label text="Nombre Completo" styleClass="label-form"/>
                <TextField fx:id="txtNombre" promptText="Ingrese su nombre" styleClass="text-field"/>
            </VBox>
            
            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                <Label text="Teléfono" styleClass="label-form"/>
                <TextField fx:id="txtTelefono" promptText="Ingrese su teléfono" styleClass="text-field"/>
            </VBox>
            
            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                <Label text="Email" styleClass="label-form"/>
                <TextField fx:id="txtEmail" promptText="Ingrese su email" styleClass="text-field"/>
            </VBox>
        </HBox>

        <!-- Servicios y horario -->
        <Label text="DETALLES DE LA CITA" styleClass="section-title"/>
        
        <HBox spacing="20.0">
            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                <Label text="Servicio" styleClass="label-form"/>
                <ComboBox fx:id="cmbServicio" prefWidth="150.0" styleClass="combo-box"/>
            </VBox>
            
            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                <Label text="Estilista" styleClass="label-form"/>
                <ComboBox fx:id="cmbEstilista" prefWidth="150.0" styleClass="combo-box"/>
            </VBox>
            
            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                <Label text="Fecha" styleClass="label-form"/>
                <DatePicker fx:id="dpFecha" styleClass="date-picker"/>
            </VBox>
            
            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                <Label text="Hora" styleClass="label-form"/>
                <ComboBox fx:id="cmbHora" prefWidth="100.0" styleClass="combo-box"/>
            </VBox>
        </HBox>

        <!-- Botones -->
        <HBox spacing="10.0" alignment="CENTER" VBox.vgrow="ALWAYS" style="-fx-padding: 30 0 0 0;">
            <Button fx:id="btnAgendar" text="AGENDAR CITA" 
                    onAction="#agendarCita" styleClass="btn-agendar"/>
            <Button fx:id="btnLimpiar" text="LIMPIAR" 
                    onAction="#limpiar" styleClass="btn-limpiar"/>
        </HBox>
    </VBox>

    <!-- Mensaje de estado -->
    <Label fx:id="lblMensaje" styleClass="lbl-mensaje"/>

</VBox>
