<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox prefHeight="700.0" prefWidth="1000.0"
      stylesheets="@/peluqueria/Css/clientes.css"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="peluqueria.Controllers.FacturacionController">

    <!-- SIDEBAR -->
    <VBox prefWidth="200" styleClass="sidebar" spacing="5">
        <padding>
            <Insets top="20" bottom="20" left="10" right="10"/>
        </padding>
        <Label text="PELUQUERIA" styleClass="sidebar-title"/>
        <Label text="Sistema de Gestion" styleClass="sidebar-subtitle"/>
        <Region prefHeight="20"/>
        <Button text="Inicio" styleClass="sidebar-btn" onAction="#irDashboard" maxWidth="Infinity"/>
        <Button text="Citas" styleClass="sidebar-btn" onAction="#irCitas" maxWidth="Infinity"/>
        <Button text="Clientes" styleClass="sidebar-btn" onAction="#irClientes" maxWidth="Infinity"/>
        <Button text="Servicios" styleClass="sidebar-btn" onAction="#irServicios" maxWidth="Infinity"/>
        <Button text="Estilistas" styleClass="sidebar-btn" onAction="#irEstilistas" maxWidth="Infinity"/>
        <Button text="Usuarios" styleClass="sidebar-btn" onAction="#irUsuarios" maxWidth="Infinity"/>
        <Button text="Caja" styleClass="sidebar-btn" onAction="#irCaja" maxWidth="Infinity"/>
        <Button text="Pagos" styleClass="sidebar-btn" onAction="#irPagos" maxWidth="Infinity"/>
        <Button text="Facturacion" styleClass="sidebar-btn-active" onAction="#irFacturacion" maxWidth="Infinity"/>
        <Region VBox.vgrow="ALWAYS"/>
        <Button text="Cerrar Sesion" styleClass="sidebar-btn-logout" onAction="#cerrarSesion" maxWidth="Infinity"/>
    </VBox>

    <!-- CONTENIDO -->
    <VBox styleClass="contenido" spacing="12" HBox.hgrow="ALWAYS">
        <padding>
            <Insets top="25" right="25" bottom="25" left="25"/>
        </padding>

        <Label text="Facturacion - Todas las Facturas" styleClass="titulo"/>
        <Label text="Consulte el historial completo de facturas" styleClass="fecha"/>

        <!-- FILTRO Y REFRESCAR -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Filtrar por estado:" styleClass="label-form"/>
            <ComboBox fx:id="cmbFiltroEstado" promptText="Todos" styleClass="campo-texto" prefWidth="160"/>
            <Button text="Filtrar" styleClass="btn-accion" onAction="#filtrar"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Refrescar" styleClass="btn-secundario" onAction="#refrescar"/>
        </HBox>

        <!-- TABLA FACTURAS -->
        <TableView fx:id="tablaFacturas" styleClass="tabla-citas" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" text="#" prefWidth="50"/>
                <TableColumn fx:id="colCliente" text="Cliente" prefWidth="180"/>
                <TableColumn fx:id="colFecha" text="Fecha" prefWidth="160"/>
                <TableColumn fx:id="colSubtotal" text="Subtotal" prefWidth="100"/>
                <TableColumn fx:id="colImpuesto" text="IVA" prefWidth="80"/>
                <TableColumn fx:id="colTotal" text="Total" prefWidth="100"/>
                <TableColumn fx:id="colEstado" text="Estado" prefWidth="100"/>
            </columns>
        </TableView>

        <!-- DETALLE -->
        <Label text="Detalle de Factura Seleccionada" styleClass="subtitulo"/>

        <TableView fx:id="tablaDetalle" styleClass="tabla-citas" prefHeight="150">
            <columns>
                <TableColumn fx:id="colDetServicio" text="Servicio" prefWidth="200"/>
                <TableColumn fx:id="colDetEstilista" text="Estilista" prefWidth="150"/>
                <TableColumn fx:id="colDetPrecio" text="Precio" prefWidth="100"/>
                <TableColumn fx:id="colDetSubtotal" text="Subtotal" prefWidth="100"/>
            </columns>
        </TableView>

        <Label fx:id="lblMensaje" styleClass="mensaje"/>
    </VBox>
</HBox>
